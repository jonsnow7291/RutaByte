APP_ENV=development
APP_NAME=rutabyte-backend

# MySQL
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=rutabyte
DB_USER=jd
DB_PASSWORD=12345678
DATABASE_URL=mysql+pymysql://jd:12345678@127.0.0.1:3306/rutabyte
# If DATABASE_URL is empty, the app builds it from DB_HOST, DB_PORT, DB_NAME, DB_USER and DB_PASSWORD.

# JWT
JWT_ALGORITHM=RS256
JWT_ACCESS_TOKEN_EXPIRE_HOURS=8
JWT_PRIVATE_KEY_PATH=./secrets/private.pem
JWT_PUBLIC_KEY_PATH=./secrets/public.pem
JWT_SECRET_KEY=change-me-in-production

ADMIN_ROLE_ID=1
